rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ SECURESHIELD AI: Scan Data Rules
    // Only authenticated (non-anonymous) users can access their own scan history.
    match /scans/{scanId} {
      // Allow user to read if they are the owner of the document
      allow read: if request.auth != null 
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && resource.data.userId == request.auth.uid;
      
      // Allow user to create if they are logged in and tagging the scan with their UID
      allow create: if request.auth != null 
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.userId == request.auth.uid;

      // Users can only delete or update their own scans
      allow update, delete: if request.auth != null 
        && resource.data.userId == request.auth.uid;
    }
    
    // 👤 SECURESHIELD AI: User Profile Rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 🚫 DEFAULT: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
